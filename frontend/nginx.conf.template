server {
    listen 8080;
    root /usr/share/nginx/html;
    index index.html;

    # ── API proxy ─────────────────────────────────────────────────────────────
    # Forwards all /api/* requests to the FastAPI backend service.
    # BACKEND_URL is set as a Railway environment variable on the FRONTEND service.
    # Example value: https://arts-and-tech-backend-production.up.railway.app
    # (no trailing slash)
    location /api/ {
        proxy_pass ${BACKEND_URL}/api/;
        proxy_http_version 1.1;

        # Preserve the original host so FastAPI CORS/trust logic works correctly
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Allow enough time for LLM-backed endpoints (staff meeting, AI tutor, etc.)
        proxy_read_timeout 120s;
        proxy_connect_timeout 10s;
        proxy_send_timeout 30s;
    }

    # ── React SPA ─────────────────────────────────────────────────────────────
    location / {
        try_files $uri $uri/ /index.html;
    }
}
