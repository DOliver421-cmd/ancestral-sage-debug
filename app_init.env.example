# ============================================================================
# WAI INSTITUTE CONFIGURATION
# Copy this to .env and fill in actual values
# ============================================================================

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=development  # development, staging, production
DEBUG=False
LOG_LEVEL=INFO

# ============================================================================
# DATABASE (MongoDB)
# ============================================================================
# Local development
MONGODB_URI=mongodb://localhost:27017/wai_institute

# MongoDB Atlas (cloud)
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/wai_institute

# ============================================================================
# STRIPE (Payment Processing)
# ============================================================================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_51234567890abcdefghijklmnop
STRIPE_WEBHOOK_SECRET=whsec_test_1234567890abcdefghijklmnop

# For Stripe Connect (creator payouts)
# STRIPE_CONNECT_PLATFORM_ACCOUNT_ID=acct_1234567890abcdef

# ============================================================================
# AUTHENTICATION
# ============================================================================
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# EMAIL (SendGrid)
# ============================================================================
# Optional: For sending subscription confirmation, payment reminders, renewals
SENDGRID_API_KEY=SG.1234567890abcdefghijklmnop
ADMIN_EMAIL=oldthug957@gmail.com
SUPPORT_EMAIL=souppoetry@gmail.com
NOREPLY_EMAIL=poetgames@gmail.com

# ============================================================================
# SLACK (Notifications & Alerts)
# ============================================================================
# Optional: For sending job alerts, payment failures, etc.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXXXXXX/YYYYYYYYY/ZZZZZZZZ
SLACK_ALERTS_CHANNEL=#alerts

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================
# Comma-separated list of allowed origins for frontend
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://wai-institute.com

# ============================================================================
# BUSINESS SETTINGS
# ============================================================================
CREATOR_REVENUE_SHARE=0.7  # Creators get 70%
PLATFORM_COMMISSION=0.3     # Platform takes 30%
CREATOR_PAYOUT_MINIMUM=50   # Minimum $50 payout threshold
MONTHLY_PAYOUT_DAY=1        # Process payouts on 1st of month

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_STRIPE=True
ENABLE_PAYOUTS=False  # Set to True after testing
ENABLE_EMAILS=False   # Set to True after configuring SendGrid
ENABLE_SLACK_ALERTS=False  # Set to True after configuring Slack
