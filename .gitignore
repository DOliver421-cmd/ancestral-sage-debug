!frontend/public/logo-*.png
!frontend/public/favicon.ico
*.woff
*.woff2
*.ttf
*.otf
*.eot

# Archive directory — historical reference only, not part of the live codebase
.archive/

# Operational scripts (may contain local paths / credentials)
scripts/ops/
