.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/
dist

# Environment and credential files — NO .env VARIANT should EVER be committed
.env
.env.*
.env*
*.env
*env*.txt
*env*.text
backend/serverpytext.txt
*token.json*
*credentials.json*
credentials.json
*.pem
*.key
.credentials

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store
Thumbs.db
Desktop.ini

# Python
__pycache__/
*pyc*
venv/
.venv/

# Development tools
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac

# Deployment
.vercel

