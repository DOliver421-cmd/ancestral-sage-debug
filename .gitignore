agenthub/agents/youtube/db

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/

# Local files
memory/test_credentials.md
WAI_Handoff.txt

# Binary / document formats that should never be committed
*.doc
*.docx
*.pdf
*.png
*.jpg
*.jpeg
*.gif
*.ico
